# KnowledgeGraph AI 后端环境变量配置
# 复制为 .env 后填写真实值。所有配置通过环境变量管理（AI 宪法：配置环境变量管理）

# 应用
APP_NAME="KnowledgeGraph AI"
DEBUG=true
API_V1_PREFIX="/api/v1"

# 安全（JWT）
# 生产环境请替换为强随机字符串：openssl rand -hex 32
SECRET_KEY="dev-secret-change-me-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库（MVP 阶段用 SQLite 占位，保持简单；后续切换 PostgreSQL）
# 切换 PostgreSQL 示例：postgresql+asyncpg://user:pass@localhost:5432/kg_ai
DATABASE_URL="sqlite:///./kg_ai.db"

# CORS：前端开发地址
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# AI（后续 Phase 启用，MVP 先占位）
# 这是「全局兜底 Key」：仅当用户未配置自己的 Key 时才使用（扣部署者额度）。
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_MODEL="text-embedding-3-small"
# LLM_MODEL="gpt-4o-mini"

# 用户自有 API Key（按用户计费）：用户在前端「设置」里填自己的 Key，
# 填了之后 LLM 调用扣该用户自己的额度，不再用上面的全局兜底。
# 是否允许「用户没填 key 时用全局兜底」——设为 false 则没填就用不了 LLM。
# ALLOW_GLOBAL_LLM_FALLBACK=true
# 加密存储用户私有 Key 的主密钥（生产必填，随机长串）。缺省用 SECRET_KEY 派生。
# LLM_KEY_MASTER=""

# 向量库（后续 Phase 启用）
# CHROMA_PERSIST_DIR="./chroma"

# 知识图谱（后续 Phase 启用）
# NEO4J_URI="bolt://localhost:7687"
# NEO4J_USER="neo4j"
# NEO4J_PASSWORD=""
