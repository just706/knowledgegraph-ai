# ====== 应用安全（务必修改为随机长字符串）======
SECRET_KEY=change-me-to-a-random-long-string
# 用户私有 LLM Key 加密主密钥（不填则自动由 SECRET_KEY 派生，建议单独设）
LLM_KEY_MASTER=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====== 数据库（Docker 内已映射到挂载卷，无需改）======
DATABASE_URL=sqlite:////app/data/kg_ai.db
CHROMA_PERSIST_DIR=/app/data/chroma

# ====== CORS ======
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ====== 全局兜底 LLM（用户未填自己 Key 时是否用部署者额度）======
# 设为 False 则"用户没填 key 就用不了 LLM"，更安全
ALLOW_GLOBAL_LLM_FALLBACK=True

# ====== 默认 LLM 配置（用户未单独设置时作为兜底预设）======
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ====== 可选：Neo4j（当前代码为关系表模拟图，未真正使用）======
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
